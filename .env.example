DEBUG=false
SECRET_KEY=replace-me
ALLOWED_HOSTS=*

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200
CORS_ALLOWED_ORIGIN_PATTERNS=
# Optional override. If unset, all origins are allowed automatically when DEBUG=true.
# CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key,warehouse,X-Facility-Id,X-Org-Id,X-Request-ID,company-code,x-geolocation,x-web-version
CORS_PREFLIGHT_MAX_AGE=86400

# Firebase verification (server-side Admin SDK)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"demo-project","private_key_id":"replace","private_key":"-----BEGIN PRIVATE KEY-----\\nreplace\\n-----END PRIVATE KEY-----\\n","client_email":"service-account@demo-project.iam.gserviceaccount.com","client_id":"replace","token_uri":"https://oauth2.googleapis.com/token"}
# Or point to a mounted file instead:
# FIREBASE_SERVICE_ACCOUNT_PATH=/app/auth/firebase_service_account.json
FIREBASE_PROJECT_ID=demo-project
FIREBASE_STORAGE_BUCKET=
BOOTSTRAP_PLATFORM_ADMIN_UIDS=

# Firebase Web SDK (client-side, for MCP OAuth2 login page)
# Get these from Firebase Console → Project Settings → Your Apps → Web app
FIREBASE_WEB_API_KEY=AIzaSy-replace-me
FIREBASE_AUTH_DOMAIN=demo-project.firebaseapp.com

# Transitional auth fallback
AUTH_FALLBACK_ENABLED=true
LEGACY_API_KEYS={"legacy_client":"legacy-secret"}

# Document generation (upload HTML docs to Firebase Storage on transaction completion)
DOCUMENT_GENERATION_ENABLED=false

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=yes_wms
DB_USER=yes
DB_PASSWORD=yes
DB_HOST=db
DB_PORT=5432

# Logging
LOG_LEVEL=INFO
LOG_DESTINATION=file
LOG_FORMAT=json
LOG_INCLUDE_PAYLOADS=true
LOG_REDACT_KEYS=authorization,x-api-key,api_key,token,access_token,refresh_token,client_secret,password,secret,private_key,firebase_service_account_json
LOG_FILE_PATH=/app/logs/yes-wms.log
LOG_FILE_MAX_BYTES=52428800
LOG_FILE_BACKUP_COUNT=10

# Firehose, used only when LOG_DESTINATION=firehose
FIREHOSE_DELIVERY_STREAM_NAME=
FIREHOSE_AWS_REGION=
FIREHOSE_BATCH_SIZE=10
FIREHOSE_FLUSH_INTERVAL_SECONDS=5
FIREHOSE_AWS_ACCESS_KEY_ID=
FIREHOSE_AWS_SECRET_ACCESS_KEY=
